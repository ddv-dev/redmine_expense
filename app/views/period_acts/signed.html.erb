<h2>Подписанные акты</h2>

<%= render 'shared/expense_menu' %>

<% if expense_manager? && @acts.any? %>
  <div style="margin-bottom: 15px;">
    <%= form_tag clear_period_acts_path(project_id: @project.id), method: :post, style: 'display:inline;' do %>
      <%= submit_tag 'Очистить',
            class: 'btn btn-danger',
            style: 'padding: 6px 20px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;',
            data: { confirm: 'Удалить ВСЕ подписанные акты этого проекта вместе с их PDF-файлами? Это действие нельзя отменить.' } %>
    <% end %>
  </div>
<% end %>

<% if @acts.any? %>
  <table class="list">
    <thead>
      <tr>
        <th>ID</th>
        <th>Период</th>
        <th>Создал</th>
        <th>Подписан</th>
        <th>PDF</th>
      </tr>
    </thead>
    <tbody>
      <% @acts.each do |act| %>
        <tr>
          <td><%= link_to act.id, period_act_show_path(id: act.id, project_id: @project.id) %></td>
          <td><%= format_date(act.start_date) %> — <%= format_date(act.end_date) %></td>
          <td><%= act.creator&.name || 'Неизвестен' %></td>
          <td><%= format_time(act.updated_at) %></td>
          <td>
            <% if act.pdf_file.present? %>
              <%= link_to 'Скачать PDF', download_pdf_period_act_path(id: act.id, project_id: @project.id) %>
            <% else %>
              <span style="color: #999;">Нет</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="nodata">Нет подписанных актов</p>
<% end %>
