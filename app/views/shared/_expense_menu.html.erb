<div style="display: flex; gap: 10px; margin-bottom: 20px; padding: 10px; background: #f8f9fa; border-radius: 8px; border: 1px solid #dee2e6; flex-wrap: wrap; align-items: center;">
  <div style="display: flex; gap: 10px; flex-wrap: wrap;">
    <%= link_to '📊 Главная', expense_index_path,
        class: 'btn btn-primary',
        style: "padding: 8px 20px; background: #{current_page?(expense_index_path) ? '#3e5b76' : '#6c757d'}; color: white; text-decoration: none; border-radius: 4px; border: none; cursor: pointer;" %>

    <% if expense_authorized?(:view_expense_history) %>
      <%= link_to '📋 История списаний', history_index_path,
          class: 'btn btn-primary',
          style: "padding: 8px 20px; background: #{current_page?(history_index_path) ? '#3e5b76' : '#6c757d'}; color: white; text-decoration: none; border-radius: 4px; border: none; cursor: pointer;" %>
    <% end %>

    <% if expense_authorized?(:view_expense_stock) %>
      <%= link_to '📦 Остатки по складу', stock_index_path,
          class: 'btn btn-primary',
          style: "padding: 8px 20px; background: #{current_page?(stock_index_path) ? '#3e5b76' : '#6c757d'}; color: white; text-decoration: none; border-radius: 4px; border: none; cursor: pointer;" %>
    <% end %>

    <% if expense_authorized?(:view_intermediate_expense) %>
      <%= link_to '⏳ Ожидают подтверждения', intermediate_index_path,
          class: 'btn btn-primary',
          style: "padding: 8px 20px; background: #{current_page?(intermediate_index_path) ? '#3e5b76' : '#6c757d'}; color: white; text-decoration: none; border-radius: 4px; border: none; cursor: pointer;" %>
    <% end %>

    <% if expense_authorized?(:manage_expense_stock) %>
      <%= link_to '📥 Импорт', new_import_path,
          class: 'btn btn-primary',
          style: "padding: 8px 20px; background: #{current_page?(new_import_path) ? '#3e5b76' : '#6c757d'}; color: white; text-decoration: none; border-radius: 4px; border: none; cursor: pointer;" %>
    <% end %>
  </div>

  <% if expense_authorized?(:manage_expense_stock) %>
    <div style="margin-left: auto;">
      <%= link_to '🗑️ Очистить склад', clear_stock_expense_path,
          class: 'btn btn-danger',
          style: 'padding: 8px 20px; background: #dc3545; color: white; text-decoration: none; border-radius: 4px;' %>
    </div>
  <% end %>
</div>
