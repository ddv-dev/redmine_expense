<h2>Ожидают подтверждения</h2>

<%= render 'shared/expense_menu' %>

<% if @intermediates.any? %>
  <table class="list">
    <thead>
      <tr>
        <th>Задача</th>
        <th>Материал</th>
        <th>Количество</th>
        <th>Кто добавил</th>
        <th>Автор задачи</th>
        <th>Дата</th>
        <th>Статус</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% @intermediates.each do |item| %>
        <tr>
          <td>
            <% if item.issue_id %>
              <%= link_to "##{item.issue_id}", issue_path(item.issue_id) %>
            <% else %>
              -
            <% end %>
          </td>
          <td><%= item.material_stock&.display_name || 'Удален' %></td>
          <td><%= item.quantity_used %></td>
          <td><%= item.user&.name || 'Неизвестен' %></td>
          <td><%= item.author&.name || 'Неизвестен' %></td>
          <td><%= format_time(item.created_at) %></td>
          <td><%= item.status %></td>
          <td>
            <% if item.pending? && expense_manager? %>
              <%= form_tag approve_intermediate_path(id: item.id, project_id: @project.id), method: :put,
                    style: 'display: inline-flex; gap: 4px; align-items: center; margin-right: 8px;' do %>
                <%= date_field_tag :closed_at, Date.current, id: "closed_at_#{item.id}", style: 'width: 135px; height: 26px; font-size: 12px;' %>
                <%= submit_tag 'Подтвердить',
                      data: { confirm: 'Подтвердить списание указанной датой?' },
                      style: 'padding: 2px 8px; color: green; background: none; border: 1px solid green; border-radius: 3px; cursor: pointer;' %>
              <% end %>
              <%= link_to 'Отклонить', reject_intermediate_path(id: item.id, project_id: @project.id), method: :put,
                      data: { confirm: 'Отклонить списание?' },
                      style: 'padding: 2px 8px; color: red; text-decoration: none;' %>
            <% else %>
              <span style="color: #999;"><%= item.status %></span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= pagination_links_full @intermediate_pages, @intermediate_count %>
<% else %>
  <p class="nodata">Нет записей, ожидающих подтверждения</p>
<% end %>
