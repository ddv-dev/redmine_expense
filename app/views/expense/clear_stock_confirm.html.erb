<h2>Очистка склада</h2>

<%= render 'shared/expense_menu' %>

<div class="box" style="background: #f8d7da; border: 2px solid #dc3545; border-radius: 8px; padding: 20px; margin: 20px 0;">
  <h3 style="color: #dc3545;">ВНИМАНИЕ!</h3>
  <p style="font-size: 16px; color: #721c24;">
    Вы собираетесь полностью очистить склад. Это действие <strong>НЕЛЬЗЯ ОТМЕНИТЬ</strong>!
  </p>

  <div style="background: white; padding: 15px; border-radius: 4px; margin: 15px 0;">
    <p><strong>Будет удалено:</strong></p>
    <ul>
      <li><strong><%= MaterialStock.count %></strong> материалов со склада</li>
      <li><strong><%= IntermediateExpense.count %></strong> записей в промежуточной таблице</li>
      <li><strong><%= ExpenseHistory.count %></strong> записей истории списаний</li>
    </ul>
  </div>

  <p style="color: #721c24; font-weight: bold;">
    Эта операция удалит все данные без возможности восстановления!
  </p>
</div>

<div style="display: flex; gap: 15px; margin-top: 20px;">
  <%= form_tag clear_stock_expense_path, method: :post do %>
    <%= submit_tag 'Да, очистить склад',
        class: 'btn btn-danger',
        style: 'padding: 10px 30px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px;',
        data: { confirm: 'Вы уверены? Это действие нельзя отменить!' } %>
  <% end %>

  <%= link_to 'Отмена', expense_index_path,
      class: 'btn btn-secondary',
      style: 'padding: 10px 30px; background: #6c757d; color: white; text-decoration: none; border-radius: 4px;' %>
</div>
