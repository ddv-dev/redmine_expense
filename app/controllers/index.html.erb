<h2><%= l(:label_expense) %></h2>

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px;">
  <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; text-align: center;">
    <h3 style="margin: 0; color: #007bff;"><%= MaterialStock.count %></h3>
    <p style="margin: 5px 0 0; color: #666;">Всего материалов</p>
  </div>
  <div style="background: #fff3cd; padding: 20px; border-radius: 8px; text-align: center;">
    <h3 style="margin: 0; color: #856404;"><%= IntermediateExpense.pending.count %></h3>
    <p style="margin: 5px 0 0; color: #856404;">Ожидают подтверждения</p>
  </div>
  <div style="background: #d4edda; padding: 20px; border-radius: 8px; text-align: center;">
    <h3 style="margin: 0; color: #155724;"><%= ExpenseHistory.count %></h3>
    <p style="margin: 5px 0 0; color: #155724;">Всего списаний</p>
  </div>
  <div style="background: #cce5ff; padding: 20px; border-radius: 8px; text-align: center;">
    <h3 style="margin: 0; color: #004085;"><%= MaterialStock.sum(:quantity).to_i %></h3>
    <p style="margin: 5px 0 0; color: #004085;">Общее количество</p>
  </div>
</div>

<div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
  <%= link_to '📋 История списаний', history_index_path, class: 'btn btn-primary' %>
  <%= link_to '📦 Остатки по складу', stock_index_path, class: 'btn btn-primary' %>
  <%= link_to '⏳ Ожидают подтверждения', intermediate_index_path, class: 'btn btn-warning' %>
  <%= link_to '📥 Импорт', new_import_path, class: 'btn btn-primary' %>
</div>

<h3>Последние списания</h3>
<table class="list">
  <thead>
    <tr>
      <th>Задача</th>
      <th>Материал</th>
      <th>Количество</th>
      <th>Кто списал</th>
      <th>Дата</th>
    </tr>
  </thead>
  <tbody>
    <% ExpenseHistory.order(closed_at: :desc).limit(10).each do |expense| %>
      <tr>
        <td><%= link_to "##{expense.issue_id}", issue_path(expense.issue_id) if expense.issue_id %></td>
        <td><%= expense.material_stock&.display_name || 'Не найден' %></td>
        <td><%= expense.quantity_used %></td>
        <td><%= expense.user&.name || 'Неизвестен' %></td>
        <td><%= format_time(expense.closed_at) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if ExpenseHistory.count == 0 %>
  <p class="nodata">Нет данных о списаниях</p>
<% end %>
