<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    font-family: DejaVu Sans, Arial, sans-serif;
  }

  /* Область footer'а в wkhtmltopdf зарезервирована отдельно от основного
     контента (высота = margin-bottom страницы, см. PeriodAct#generate_pdf!),
     поэтому блок подписей физически не может наехать на таблицу. Ширина
     этой резервации подбирается под фактическое число членов комиссии —
     justify-content: flex-end прижимает список к нижнему краю области. */
  .sig-wrap {
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 15mm 20mm 30mm;
  }
  .sig-role { font-weight: bold; margin: 8px 0 4px; font-size: 12px; color: #222; }
  .sig-plain { display: flex; align-items: flex-end; gap: 15px; margin-bottom: 6px; }
  .sig-plain .sig-line { flex: 0 0 200px; border-bottom: 1px solid #333; height: 14px; }
  .sig-plain .sig-name { font-size: 12px; color: #222; }
  .esign-box { border: 2px solid #2b57d6; border-radius: 4px; padding: 6px 10px; color: #2b57d6; margin-bottom: 6px; max-width: 420px; }
  .esign-box p { margin: 1px 0; font-size: 11px; }
</style>
</head>
<body>
  <div class="sig-wrap">
    <% if chairman %>
      <div class="sig-role">Председатель</div>
      <div class="sig-plain">
        <span class="sig-line"></span>
        <span class="sig-name"><%= chairman.name %></span>
      </div>
    <% end %>

    <div class="sig-role">Члены комиссии</div>
    <% signatures.each do |signature| %>
      <% if signature.status == 'signed' %>
        <div class="esign-box">
          <p>Документ подписан простой электронной подписью</p>
          <p>ФИО: <%= signature.user&.name %></p>
          <p>Логин: <%= signature.user&.login %></p>
          <p>Дата подписания: <%= signature.signed_at ? format_time(signature.signed_at) : '-' %></p>
        </div>
      <% else %>
        <div class="sig-plain">
          <span class="sig-line"></span>
          <span class="sig-name"><%= signature.user&.name %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</body>
</html>
