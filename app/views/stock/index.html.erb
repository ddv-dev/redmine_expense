<h2>Остатки по складу</h2>

<%= render 'shared/expense_menu' %>

<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin: 20px 0;">
  <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; text-align: center;">
    <h3 style="margin: 0; color: #007bff;"><%= @total_items %></h3>
    <p style="margin: 5px 0 0; color: #666;">Всего наименований</p>
  </div>
  <div style="background: #d4edda; padding: 15px; border-radius: 8px; text-align: center;">
    <h3 style="margin: 0; color: #155724;"><%= @total_quantity %></h3>
    <p style="margin: 5px 0 0; color: #155724;">Общее количество</p>
  </div>
  <div style="background: #f8d7da; padding: 15px; border-radius: 8px; text-align: center;">
    <h3 style="margin: 0; color: #721c24;"><%= @low_stock %></h3>
    <p style="margin: 5px 0 0; color: #721c24;">Мало (менее 10)</p>
  </div>
</div>

<% if expense_manager? %>
  <div style="margin-bottom: 15px; display: flex; gap: 10px;">
    <%= link_to 'Экспорт в Excel', export_stock_path(project_id: @project.id), class: 'btn btn-primary' %>
    <button type="button" id="stock-add-btn" class="btn btn-primary">+ Добавить позицию</button>
  </div>
<% end %>

<table class="list">
  <thead>
    <tr>
      <th>Номенклатура</th>
      <th>Наименование поставщика</th>
      <th>Модификация</th>
      <th>Количество</th>
      <th>Описание</th>
      <% if expense_manager? %>
        <th>Действия</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @materials.each do |material| %>
      <tr id="material-row-<%= material.id %>">
        <td><%= material.material_type %></td>
        <td><%= material.brand %></td>
        <td><%= material.model %></td>
        <td style="<%= 'color: red; font-weight: bold;' if material.low_stock? %>">
          <%= material.quantity %>
        </td>
        <td><%= material.description %></td>
        <% if expense_manager? %>
          <td>
            <a href="#" class="edit-material-link" data-id="<%= material.id %>" title="Редактировать">Изменить</a>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @materials.empty? %>
  <p class="nodata">Нет материалов на складе</p>
<% end %>


<span class="pagination" style="margin-top:40px"> <%= pagination_links_full @material_pages, @material_count %></span>

<% if expense_manager? %>
  <div id="stock-add-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000;">
    <div style="background:white; max-width:420px; margin:80px auto; padding:20px; border-radius:8px;">
      <h3>Добавить позицию на склад</h3>
      <%= form_tag create_stock_path(project_id: @project.id), method: :post do %>
        <p>
          <label>Номенклатура</label><br>
          <%= text_field_tag 'material_stock[material_type]', nil, style: 'width:100%;' %>
        </p>
        <p>
          <label>Наименование поставщика</label><br>
          <%= text_field_tag 'material_stock[brand]', nil, style: 'width:100%;' %>
        </p>
        <p>
          <label>Модификация</label><br>
          <%= text_field_tag 'material_stock[model]', nil, style: 'width:100%;' %>
        </p>
        <p>
          <label>Количество</label><br>
          <%= number_field_tag 'material_stock[quantity]', nil, step: '0.01', min: '0', style: 'width:100%;' %>
        </p>
        <p>
          <label>Описание</label><br>
          <%= text_area_tag 'material_stock[description]', nil, style: 'width:100%;' %>
        </p>
        <div style="display:flex; gap:10px; justify-content:flex-end;">
          <button type="button" id="stock-add-cancel" class="btn btn-secondary">Отмена</button>
          <%= submit_tag 'Добавить', class: 'btn btn-primary' %>
        </div>
      <% end %>
    </div>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var addModal = document.getElementById('stock-add-modal');
    document.getElementById('stock-add-btn').addEventListener('click', function() {
      addModal.style.display = 'block';
    });
    document.getElementById('stock-add-cancel').addEventListener('click', function() {
      addModal.style.display = 'none';
    });
  });
  </script>
<% end %>

<div id="stock-edit-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000;">
  <div style="background:white; max-width:420px; margin:80px auto; padding:20px; border-radius:8px;">
    <h3>Редактировать материал</h3>
    <div id="stock-edit-error" style="display:none; color:#dc3545; margin-bottom:10px;"></div>
    <p>
      <label>Номенклатура</label><br>
      <input type="text" id="edit-material-type" style="width:100%;">
    </p>
    <p>
      <label>Наименование поставщика</label><br>
      <input type="text" id="edit-brand" style="width:100%;">
    </p>
    <p>
      <label>Модификация</label><br>
      <input type="text" id="edit-model" style="width:100%;">
    </p>
    <p>
      <label>Количество</label><br>
      <input type="number" step="0.01" min="0" id="edit-quantity" style="width:100%;">
    </p>
    <p>
      <label>Описание</label><br>
      <textarea id="edit-description" style="width:100%;"></textarea>
    </p>
    <div style="display:flex; gap:10px; justify-content:flex-end;">
      <button type="button" id="stock-edit-cancel" class="btn btn-secondary">Отмена</button>
      <button type="button" id="stock-edit-save" class="btn btn-primary">Сохранить</button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var modal = document.getElementById('stock-edit-modal');
  var currentId = null;

  document.querySelectorAll('.edit-material-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      currentId = this.dataset.id;
      document.getElementById('stock-edit-error').style.display = 'none';

      fetch('/projects/<%= @project.id %>/stock/' + currentId + '/edit', { headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(material) {
          document.getElementById('edit-material-type').value = material.material_type || '';
          document.getElementById('edit-brand').value = material.brand || '';
          document.getElementById('edit-model').value = material.model || '';
          document.getElementById('edit-quantity').value = material.quantity || 0;
          document.getElementById('edit-description').value = material.description || '';
          modal.style.display = 'block';
        });
    });
  });

  document.getElementById('stock-edit-cancel').addEventListener('click', function() {
    modal.style.display = 'none';
  });

  document.getElementById('stock-edit-save').addEventListener('click', function() {
    var payload = {
      material_stock: {
        material_type: document.getElementById('edit-material-type').value,
        brand: document.getElementById('edit-brand').value,
        model: document.getElementById('edit-model').value,
        quantity: document.getElementById('edit-quantity').value,
        description: document.getElementById('edit-description').value
      }
    };

    fetch('/projects/<%= @project.id %>/stock/' + currentId, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify(payload)
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          location.reload();
        } else {
          var errorBox = document.getElementById('stock-edit-error');
          errorBox.textContent = (data.errors || ['Ошибка сохранения']).join(', ');
          errorBox.style.display = 'block';
        }
      });
  });
});
</script>
