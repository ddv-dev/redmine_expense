<style>
  .settings-section {
    margin-bottom: 20px;
    padding: 15px;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    background: #f9f9f9;
    overflow: hidden;
  }
  .settings-section .section-title {
    font-weight: bold;
    font-size: 14px;
    display: block;
    margin-bottom: 10px;
    color: #333;
    border-bottom: 2px solid #3e5b76;
    padding-bottom: 5px;
  }
  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px 20px;
    padding: 5px 0;
  }
  .checkbox-grid label {
    display: flex;
    align-items: center;
    padding: 2px 0;
    font-weight: normal;
    cursor: pointer;
    font-size: 13px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .checkbox-grid input[type="checkbox"],
  .checkbox-grid input[type="radio"] {
    margin-right: 8px;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }

  /* Настройка для .tabular.settings label */
  .tabular.settings label {
    margin-left: 10px;
    width: 295px;
  }

  .settings-hint {
    display: block;
    margin-top: 10px;
    color: #666;
    font-size: 0.85em;
    font-style: italic;
    padding: 5px 0 0 0;
    border-top: 1px dashed #ddd;
    clear: both;
  }
  .radio-group {
    display: block;
    padding: 5px 0;
  }
  .radio-group label {
    display: inline-flex;
    align-items: center;
    margin-right: 20px;
    padding: 2px 0;
    font-weight: normal;
    cursor: pointer;
    font-size: 13px;
  }
  .radio-group input[type="radio"] {
    margin-right: 8px;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }
</style>

<h2>Настройки плагина "Расход"</h2>

<p class="settings-hint" style="border-top: none; padding-top: 0;">
  Плагин включается для конкретного проекта на вкладке "Настройки проекта" -> "Модули" (модуль "Расход"),
  а список менеджеров/добавляющих материалы для каждого проекта настраивается на вкладке
  "Расход" в настройках самого проекта. Здесь задаются только общие для всех проектов правила.
</p>

<!-- Трекеры -->
<div class="settings-section">
  <span class="section-title">Трекеры</span>
  <div class="checkbox-grid">
    <% Tracker.all.each do |tracker| %>
      <label>
        <%= check_box_tag 'settings[tracker_ids][]', tracker.id, @settings['tracker_ids'].to_a.include?(tracker.id.to_s) %>
        <%= tracker.name %>
      </label>
    <% end %>
  </div>
  <span class="settings-hint">Выберите трекеры, для которых будет доступен функционал</span>
</div>

<!-- Статусы, при которых можно добавлять материалы -->
<%
  # Переезд со старой схемы: если новый мультивыбор еще не сохраняли,
  # предзаполняем его прежними статусами "В работе"/"Решена".
  material_statuses = Array(@settings['material_statuses']).map(&:to_s)
  if material_statuses.empty?
    material_statuses = [@settings['status_in_progress'], @settings['status_resolved']].map(&:to_s).reject(&:blank?)
  end
%>
<div class="settings-section">
  <span class="section-title">Статусы, при которых можно добавлять материалы к задаче</span>
  <div class="checkbox-grid">
    <% IssueStatus.all.each do |status| %>
      <label>
        <%= check_box_tag 'settings[material_statuses][]', status.id, material_statuses.include?(status.id.to_s) %>
        <%= status.name %>
      </label>
    <% end %>
  </div>
  <span class="settings-hint">Блок "Расходные материалы" появится в форме редактирования задачи, когда задача находится в любом из отмеченных статусов</span>
</div>

<!-- Статус "Закрыта" -->
<div class="settings-section">
  <span class="section-title">Статус автоматического подтверждения списаний</span>
  <div class="radio-group">
    <% IssueStatus.all.each do |status| %>
      <label>
        <%= radio_button_tag 'settings[status_closed]', status.id, @settings['status_closed'].to_s == status.id.to_s %>
        <%= status.name %>
      </label>
    <% end %>
  </div>
  <span class="settings-hint">При переводе задачи в этот статус все её ожидающие списания подтверждаются автоматически (списывается остаток, формируется PDF-акт)</span>
</div>
