<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 14px; color: #222; margin: 20px; }
  h1 { font-size: 20px; margin: 0 0 15px; }
  .meta p { margin: 2px 0; }
  table.materials { width: 100%; border-collapse: collapse; margin: 20px 0; }
  table.materials th, table.materials td { border: 1px solid #333; padding: 6px 8px; text-align: left; font-size: 14px; }
  table.materials th { background: #f0f0f0; }
</style>
</head>
<body>
  <h1>Заказ-наряд по задаче #<%= issue.id %></h1>

  <div class="meta">
    <p><%= issue.subject %></p>
    <p>Проект: <%= issue.project&.name %></p>
    <p>Автор: <%= issue.author&.name %></p>
    <p>Дата формирования: <%= RedmineExpense::RussianDate.short(history.closed_at) %></p>
  </div>

  <table class="materials">
    <thead>
      <tr>
        <th>Наименование номенклатуры</th>
        <th>Наименование поставщика</th>
        <th>Модификация</th>
        <th>Кол-во</th>
        <th>Комментарий</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><%= history.material_stock&.display_material_name %></td>
        <td><%= history.material_stock&.brand %></td>
        <td><%= history.material_stock&.model %></td>
        <td><%= history.quantity_used %></td>
        <td><%= history.material_stock&.description %></td>
      </tr>
    </tbody>
  </table>
</body>
</html>
