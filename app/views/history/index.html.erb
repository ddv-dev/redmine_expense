<% expense_project_setting = ExpenseProjectSetting.for_project(@project) %>
<% act_committee_users = User.where(id: expense_project_setting.committee_id_list).sorted %>
<% act_chairman = expense_project_setting.chairman_id.present? ? User.find_by(id: expense_project_setting.chairman_id) : nil %>

<h2>История списаний</h2>

<%= render 'shared/expense_menu' %>

<%= form_tag history_index_path(project_id: @project.id), method: :get, id: 'history-filters', style: 'margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;' do %>
  <div>
    <label style="display:block; font-size:12px; color:#666;">Дата с</label>
    <%= date_field_tag :start_date, @filter_start_date %>
  </div>
  <div>
    <label style="display:block; font-size:12px; color:#666;">Дата по</label>
    <%= date_field_tag :end_date, @filter_end_date %>
  </div>
  <div>
    <label style="display:block; font-size:12px; color:#666;">Пользователь</label>
    <%= select_tag :user_id,
          options_from_collection_for_select(@users, :id, :name, @filter_user_id),
          include_blank: 'Все' %>
  </div>
  <div>
    <label style="display:block; font-size:12px; color:#666;">Материал</label>
    <%= select_tag :material_stock_id,
          options_from_collection_for_select(@material_stocks, :id, :display_name, @filter_material_stock_id),
          include_blank: 'Все' %>
  </div>
  <div>
    <%= submit_tag 'Фильтровать', class: 'btn btn-primary' %>
    <%= link_to 'Сбросить', history_index_path(project_id: @project.id), class: 'btn btn-secondary' %>
  </div>
<% end %>

<% if expense_manager? %>
  <div style="margin-bottom: 20px; display: flex; gap: 10px; align-items: center;">
    <button type="button" id="generate-act-btn" class="btn btn-primary">Генерация акта</button>
    <button type="button" id="export-pdf-btn" class="btn btn-primary">Скачать PDF списаний за период</button>
    <span style="color: #666; font-size: 12px;">По датам "с"/"по" из фильтра выше</span>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('export-pdf-btn').addEventListener('click', function() {
      var startDate = document.getElementById('start_date').value;
      var endDate = document.getElementById('end_date').value;
      if (!startDate || !endDate) {
        alert('Укажите период (дата с / дата по) в фильтре выше');
        return;
      }
      window.location = '<%= export_pdf_history_path(project_id: @project.id) %>' +
        '?start_date=' + encodeURIComponent(startDate) + '&end_date=' + encodeURIComponent(endDate);
    });
  });
  </script>
<% end %>

<% if @histories.any? %>
  <table class="list">
    <thead>
      <tr>
        <th>ID</th>
        <th>Задача</th>
        <th>Материал</th>
        <th>Количество</th>
        <th>Кто списал</th>
        <th>Кто закрыл</th>
        <th>Дата</th>
        <th>PDF</th>
      </tr>
    </thead>
    <tbody>
      <% @histories.each do |history| %>
        <tr>
          <td><%= link_to history.id, history_show_path(id: history.id, project_id: @project.id) %></td>
          <td>
            <% if history.issue_id %>
              <%= link_to "##{history.issue_id}", issue_path(history.issue_id) %>
            <% else %>
              -
            <% end %>
          </td>
          <td><%= history.material_stock&.display_name || 'Удален' %></td>
          <td><%= RedmineExpense::Quantity.format(history.quantity_used) %></td>
          <td><%= history.user&.name || 'Неизвестен' %></td>
          <td><%= history.closer&.name || 'Неизвестен' %></td>
          <td><%= format_time(history.closed_at) %></td>
          <td>
            <% if history.pdf_generated && history.pdf_file.present? %>
              <%= link_to 'Скачать PDF', download_pdf_history_path(id: history.id, project_id: @project.id) %>
            <% else %>
              <span style="color: #999;">Нет</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= pagination_links_full @history_pages, @history_count %>
<% else %>
  <p class="nodata">Нет данных о списаниях</p>
<% end %>

<% if expense_manager? %>
  <div id="generate-act-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000;">
    <div style="background:white; max-width:480px; margin:80px auto; padding:20px; border-radius:8px;">
      <h3>Отправить комиссии</h3>
      <p style="color:#666; font-size:13px;">Период: <strong id="generate-act-period"></strong></p>

      <% if act_committee_users.empty? %>
        <p>Комиссия не настроена. <%= link_to 'Настроить в проекте (Настройки -> Расход)', settings_project_path(@project, tab: 'expense') %></p>
      <% else %>
        <p style="font-size:13px;">Снимите галку у тех, чью подпись сейчас запрашивать не нужно (например, в отпуске) — в акте они всё равно будут числиться комиссии/председателем.</p>
        <div style="max-height:260px; overflow-y:auto; border:1px solid #e5e5e5; border-radius:4px; padding:8px;">
          <% if act_chairman && !act_committee_users.any? { |u| u.id == act_chairman.id } %>
            <div class="generate-act-signer-row" style="padding:3px 0; border-bottom:1px solid #eee; margin-bottom:6px;">
              <label style="display:block; font-weight:bold;">
                <input type="checkbox" class="generate-act-signer" value="<%= act_chairman.id %>" checked> <%= act_chairman.name %> (Председатель)
              </label>
              <input type="text" class="generate-act-skip-reason" data-user-id="<%= act_chairman.id %>"
                     placeholder="Причина, почему подпись не запрашивается (например, «В отпуске»)"
                     style="display:none; width:100%; margin:4px 0 2px; box-sizing:border-box;">
            </div>
          <% end %>
          <% act_committee_users.each do |user| %>
            <div class="generate-act-signer-row" style="padding:3px 0;">
              <label style="display:block;">
                <input type="checkbox" class="generate-act-signer" value="<%= user.id %>" checked>
                <%= user.name %><%= ' (Председатель)' if act_chairman && user.id == act_chairman.id %>
              </label>
              <input type="text" class="generate-act-skip-reason" data-user-id="<%= user.id %>"
                     placeholder="Причина, почему подпись не запрашивается (например, «В отпуске»)"
                     style="display:none; width:100%; margin:4px 0 2px; box-sizing:border-box;">
            </div>
          <% end %>
        </div>
      <% end %>

      <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:15px;">
        <button type="button" id="generate-act-cancel" class="btn btn-secondary">Отмена</button>
        <% if act_committee_users.any? %>
          <button type="button" id="generate-act-submit" class="btn btn-primary">Отправить</button>
        <% end %>
      </div>
    </div>
  </div>

  <%= form_tag generate_period_act_path(project_id: @project.id), method: :post, id: 'generate-act-form', style: 'display:none;' do %>
    <%= hidden_field_tag :start_date, '', id: 'generate-act-start-date' %>
    <%= hidden_field_tag :end_date, '', id: 'generate-act-end-date' %>
    <div id="generate-act-signer-inputs"></div>
  <% end %>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var modal = document.getElementById('generate-act-modal');
    var openBtn = document.getElementById('generate-act-btn');
    if (!openBtn) return;

    function toggleReasonInput(checkbox) {
      var row = checkbox.closest('.generate-act-signer-row');
      if (!row) return;
      var reasonInput = row.querySelector('.generate-act-skip-reason');
      if (!reasonInput) return;
      if (checkbox.checked) {
        reasonInput.style.display = 'none';
        reasonInput.value = '';
      } else {
        reasonInput.style.display = 'block';
      }
    }

    document.querySelectorAll('.generate-act-signer').forEach(function(cb) {
      toggleReasonInput(cb);
      cb.addEventListener('change', function() { toggleReasonInput(cb); });
    });

    openBtn.addEventListener('click', function() {
      var startDate = document.getElementById('start_date').value;
      var endDate = document.getElementById('end_date').value;
      if (!startDate || !endDate) {
        alert('Укажите период (дата с / дата по) в фильтре выше перед генерацией акта');
        return;
      }
      document.getElementById('generate-act-start-date').value = startDate;
      document.getElementById('generate-act-end-date').value = endDate;
      document.getElementById('generate-act-period').textContent = startDate + ' — ' + endDate;
      modal.style.display = 'block';
    });

    document.getElementById('generate-act-cancel').addEventListener('click', function() {
      modal.style.display = 'none';
    });

    var submitBtn = document.getElementById('generate-act-submit');
    if (submitBtn) {
      submitBtn.addEventListener('click', function() {
        var container = document.getElementById('generate-act-signer-inputs');
        container.innerHTML = '';
        document.querySelectorAll('.generate-act-signer').forEach(function(cb) {
          if (cb.checked) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'signer_ids[]';
            input.value = cb.value;
            container.appendChild(input);
          } else {
            var row = cb.closest('.generate-act-signer-row');
            var reasonInput = row ? row.querySelector('.generate-act-skip-reason') : null;
            var reason = reasonInput ? reasonInput.value.trim() : '';
            if (reason) {
              var reasonHidden = document.createElement('input');
              reasonHidden.type = 'hidden';
              reasonHidden.name = 'skip_reasons[' + cb.value + ']';
              reasonHidden.value = reason;
              container.appendChild(reasonHidden);
            }
          }
        });
        document.getElementById('generate-act-form').submit();
      });
    }
  });
  </script>
<% end %>
